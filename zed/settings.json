// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "main.magenta-hamster-76.weerachaiplodkaew.coder",
      "args": [],
      "projects": [
        {
          "paths": ["/home/coder/kpc-web-frontend-2"],
        },
      ],
    },
  ],
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "diff_view_style": "split",
  "search": {
    "center_on_match": false,
    "whole_word": true,
    "case_sensitive": true,
  },
  "use_smartcase_search": false,
  "lsp": {
    "vtsls": {
      "initialization_options": {
        "vtsls": {
          "autoUseWorkspaceTsdk": true,
        },
      },
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx", "clsx", "cls", "classnames", "cn"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"],
        },
      },
    },
  },
  "edit_predictions": {
    "disabled_globs": [
      "**/.env.local",
      "**/.env",
      "**/.env.test",
      "**/.env.development",
      "**/.env.production",
    ],
    "mode": "eager",
    "provider": "zed",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "opencode": {
      "default_config_options": {
        "effort": "medium",
      },
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "env": {},
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show": true,
  },
  "minimap": {
    "show": "auto",
  },
  "preferred_line_length": 80,
  "ui_font_size": 16,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Catppuccin Mocha",
  },
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
      ],
    },
    "JavaScript": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSX": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  },
  "file_finder": {
    "modal_max_width": "xlarge",
  },
}
